{% extends 'base.html.twig' %}

{% block body %}
<div class="container mt-4">
    <h1>Dashboard del Almacén</h1>
    
    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card text-bg-primary mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total de Artículos</h5>
                    <h2 class="card-text">{{ total_articulos }} unidades</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <h3 class="text-danger">Alertas de Stock</h3>
            <ul class="list-group">
                {% for prod in productos_bajos %}
                    
                    <li class="list-group-item d-flex justify-content-between align-items-center {{ prod.cantidad == 0 ? 'list-group-item-danger' : 'list-group-item-warning' }}">
                        
                        <span class="fw-bold">{{ prod.nombre }}</span>
                        
                        {% if prod.cantidad == 0 %}
                            <span class="badge bg-danger rounded-pill">Agotado (0)</span>
                        {% else %}
                            <span class="badge bg-warning text-dark rounded-pill">Últimas uds. ({{ prod.cantidad }})</span>
                        {% endif %}
                        
                    </li>
                    
                {% else %}
                    <li class="list-group-item list-group-item-success text-center">
                        <strong>Stock OK</strong> <br> Ningún producto está en peligro.
                    </li>
                {% endfor %}
            </ul>
        </div>
        <div class="col-md-6">
            <h3>Últimos movimientos</h3>
            <ul class="list-group">
                {% for mov in ultimos_movimientos %}
                    <li class="list-group-item text-muted">
                        <strong>{{ mov.producto.nombre }}</strong>: 
                        <span class="text-success">+{{ mov.cantidadCambiada }}</span> 
                        <small class="float-end">{{ mov.fecha|date('d/m H:i') }}</small>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>
    <h1>Panel de Control de Inventario</h1>
    <a href="{{ path('app_producto_index') }}" class="btn btn-lg btn-primary mt-2 mb-4">
        Gestionar Productos
    </a>
</div>
{% endblock %}
