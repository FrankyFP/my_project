{% extends 'base.html.twig' %}

{% block body %}
<div class="container mt-4">
    <h1>Dashboard del Almacén</h1>
    
    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card text-bg-primary mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total de Artículos</h5>
                    <h2 class="card-text">{{ total_articulos }} unidades</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <h3>Alerta de Stock</h3>
            <ul class="list-group">
                {% for prod in productos_bajos %}
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        {{ prod.nombre }}
                        <span class="badge {{ prod.cantidad == 0 ? 'bg-danger' : 'bg-warning' }} rounded-pill">
                            {{ prod.cantidad }}
                        </span>
                    </li>
                {% endfor %}
            </ul>
        </div>
        <div class="col-md-6">
            <h3>Últimos movimientos</h3>
            <ul class="list-group">
                {% for mov in ultimos_movimientos %}
                    <li class="list-group-item text-muted">
                        <strong>{{ mov.producto.nombre }}</strong>: 
                        <span class="text-success">+{{ mov.cantidadCambiada }}</span> 
                        <small class="float-end">{{ mov.fecha|date('d/m H:i') }}</small>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>
    <h1>Panel de Control de Inventario</h1>
    <a href="{{ path('app_producto_index') }}" class="btn btn-lg btn-primary mt-2 mb-4">
        Gestionar Productos
    </a>
</div>
{% endblock %}
