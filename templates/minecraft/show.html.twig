{% extends 'base.html.twig' %}

{% block title %}Minecraft{% endblock %}

{% block body %}
    <h1>Minecraft</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ minecraft.id }}</td>
            </tr>
            <tr>
                <th>Version</th>
                <td>{{ minecraft.version }}</td>
            </tr>
            <tr>
                <th>Plataforma</th>
                <td>{{ minecraft.Plataforma }}</td>
            </tr>
            <tr>
                <th>Gamemode</th>
                <td>{{ minecraft.gamemode }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_minecraft_index') }}">back to list</a>

    <a href="{{ path('app_minecraft_edit', {'id': minecraft.id}) }}">edit</a>

    {{ include('minecraft/_delete_form.html.twig') }}
{% endblock %}
