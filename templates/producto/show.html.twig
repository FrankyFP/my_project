{% extends 'base.html.twig' %}

{% block title %}Producto: {{ producto.nombre }}{% endblock %}

{% block body %}
    <h1>Detalles de {{ producto.nombre }}</h1>

    <div class="mb-4">
        <p><strong>Descripción:</strong> {{ producto.descripcion }}</p>
        <p><strong>Stock actual:</strong> {{ producto.cantidad }}</p>
    </div>

    <h3>Historial de Movimientos</h3>
    <table class="table mb-4">
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Movimiento</th>
            </tr>
        </thead>
        <tbody>
            {% for movimiento in producto.historialMovimientos|sort((a, b) => b.fecha <=> a.fecha) %}
            <tr>
                <td>{{ movimiento.fecha|date('d/m/Y H:i') }}</td>
                <td>
                    <span class="text-success fw-bold">+{{ movimiento.cantidadCambiada }} uds.</span>
                    <small class="text-muted ms-2">
                        (Hecho por: {{ movimiento.usuario ? movimiento.usuario.email : 'Sistema' }})
                    </small>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="2">No hay movimientos registrados.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    {# Botonera de acciones #}
    <div class="d-flex gap-2 mt-4">
        <a class="btn btn-secondary" href="{{ path('app_producto_index') }}">Volver al inventario</a>
        <a class="btn btn-primary" href="{{ path('app_producto_edit', {'id': producto.id}) }}">Editar producto</a>
        
        {# Solo mostramos el botón de borrar si el usuario es Administrador #}
        {% if is_granted('ROLE_ADMIN') %}
            {{ include('producto/_delete_form.html.twig') }}
        {% endif %}
    </div>
{% endblock %}