{% extends 'base.html.twig' %}

{% block title %}Producto: {{ producto.nombre }}{% endblock %}

{% block body %}
    <h1>Detalles de {{ producto.nombre }}</h1>

    <p><strong>Descripción:</strong> {{ producto.descripcion }}</p>
    <p><strong>Stock actual:</strong> {{ producto.cantidad }}</p>

    <h3>Historial de Movimientos</h3>
    <table class="table">
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Movimiento</th>
            </tr>
        </thead>
        <tbody>
            {# Asumiendo que al crear la relación le pusiste getHistorialMovimientos() #}
            {% for movimiento in producto.historialMovimientos|sort((a, b) => b.fecha <=> a.fecha) %}
                <tr>
                    <td>{{ movimiento.fecha|date('d/m/Y H:i:s') }}</td>
                    <td class="text-success">+{{ movimiento.cantidadCambiada }} uds.</td>
                </tr>
            {% else %}
                <tr><td colspan="2">No hay movimientos registrados.</td></tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}