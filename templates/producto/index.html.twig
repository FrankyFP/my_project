{% extends 'base.html.twig' %}

{% block title %}Lista de Productos{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Inventario</h1>
        
        <a href="{{ path('app_inicio') }}" class="btn btn-secondary">
            Volver al Inicio
        </a>
    </div>


    <h1>Inventario de Productos</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Categoría</th>
                <th>Cantidad</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
        {% for producto in productos %}
            {# Lógica de colores en la fila #}
            {% set row_class = '' %}
            {% if producto.cantidad == 0 %}
                {% set row_class = 'table-danger text-danger' %}
            {% elseif producto.cantidad >= 1 and producto.cantidad <= 5 %}
                {% set row_class = 'table-warning text-warning' %}
            {% endif %}

            <tr class="{{ row_class }}" id="fila-producto-{{ producto.id }}">
                <td>{{ producto.nombre }}</td>
                <td>{{ producto.categoria ? producto.categoria.nombre : 'Sin categoría' }}</td>
                
                <td id="cantidad-{{ producto.id }}"><strong>{{ producto.cantidad }}</strong></td>
                
                <td id="estado-{{ producto.id }}">
                    {# Columna de Estado #}
                    {% if producto.cantidad == 0 %}
                        <span class="badge bg-danger">Agotado</span>
                    {% elseif producto.cantidad >= 1 and producto.cantidad <= 5 %}
                        <span class="badge bg-warning text-dark">Últimas unidades</span>
                    {% else %}
                        <span class="badge bg-success">Stock ok</span>
                    {% endif %}
                </td>
                
                <td>
                    <a href="{{ path('app_producto_show', {'id': producto.id}) }}" class="btn btn-sm btn-info">Ver</a>
                    <a href="{{ path('app_producto_edit', {'id': producto.id}) }}" class="btn btn-sm btn-secondary">Editar</a>
        
                    {% if is_granted('ROLE_ADMIN') %}
                    {{ include('producto/_delete_form.html.twig') }}
                    {% endif %}
        
                    <button class="btn btn-sm btn-success btn-reposicion" data-id="{{ producto.id }}">+1 Reponer</button>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">No hay productos en el inventario.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_producto_new') }}">Crear nuevo</a>

    {# Script para la llamada AJAX #}
    <script>
        document.querySelectorAll('.btn-reposicion').forEach(button => {
    button.addEventListener('click', function() {
        const productoId = this.getAttribute('data-id');
        
        fetch(`/producto/${productoId}/reposicion`, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(response => response.json())
        .then(data => {
            const nuevaCantidad = data.nueva_cantidad;
            
            // 1. Actualizar el número
            document.getElementById('cantidad-' + productoId).innerHTML = `<strong>${nuevaCantidad}</strong>`;
            
            // 2. Actualizar la fila y los colores dinámicamente
            const fila = document.getElementById('fila-producto-' + productoId);
            const estadoTd = document.getElementById('estado-' + productoId);
            
            // Limpiamos las clases previas de la fila
            fila.classList.remove('table-danger', 'text-danger', 'table-warning', 'text-warning');
            
            if (nuevaCantidad == 0) {
                fila.classList.add('table-danger', 'text-danger');
                estadoTd.innerHTML = '<span class="badge bg-danger">Agotado</span>';
            } else if (nuevaCantidad >= 1 && nuevaCantidad <= 5) {
                fila.classList.add('table-warning', 'text-warning');
                estadoTd.innerHTML = '<span class="badge bg-warning text-dark">Últimas unidades</span>';
            } else {
                estadoTd.innerHTML = '<span class="badge bg-success">Stock ok</span>';
            }
        })
        .catch(error => console.error('Error:', error));
    });
});
    </script>
{% endblock %}